# Copy to pyserver/.env.

# Leave empty for free Eastmoney + AkShare + BaoStock live data.
# Use TUSHARE_TOKEN=mock only for offline deterministic demo data.
TUSHARE_TOKEN=

# Set to 1 in real-data test/prod to reject TUSHARE_TOKEN=mock.
STRICT_LIVE_DATA=0

# Optional paid/permissioned secondary source.
# Keep 0 unless the token has required Tushare permissions and frequency budget.
MARKET_ENABLE_TUSHARE_SECONDARY=0

# Optional cache path override.
# PYSERVER_CACHE_DB=/absolute/path/to/cache.db

# Optional fallback only: pyserver strips shell HTTP(S)_PROXY by default.
# Set only when direct Eastmoney push2 fails but an explicit domestic proxy works.
# MARKET_HTTP_PROXY=http://127.0.0.1:7890
