# Copy to .env for docker compose.

# LLM provider: opencode-go (recommended) or deepseek.
LLM_PROVIDER=opencode-go
OPENCODE_GO_API_KEY=your-opencode-go-api-key
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Models.
LLM_MODEL=deepseek-v4-pro
LLM_MODEL_BACKTEST=deepseek-v4-flash

# pyserver in Docker defaults to TUSHARE_TOKEN=mock.
# Use this placeholder to disable mock and use free live sources without enabling Tushare secondary.
TUSHARE_TOKEN=your-tushare-pro-token-here

# Live signals.
SIGNALS_LOAD_CONCURRENCY=3
SIGNALS_PYSERVER_TIMEOUT_MS=120000
SIGNALS_FUNDAMENTAL_TIMEOUT_MS=8000
SIGNALS_LLM_TIMEOUT_MS=900000
SIGNALS_LLM_MAX_ATTEMPTS=1
SIGNALS_LLM_SCORE_BATCH_SIZE=10

# Backtest.
BACKTEST_LOAD_CONCURRENCY=10
BACKTEST_PYSERVER_TIMEOUT_MS=60000
BACKTEST_LLM_SCORE_BATCH_SIZE=10
BACKTEST_SIGNAL_CONCURRENCY=8
BACKTEST_LLM_TIMEOUT_MS=300000
BACKTEST_LLM_MAX_ATTEMPTS=2

# Other scoreSymbols callers.
LLM_SCORE_BATCH_SIZE=10

# Universe refresh.
UNIVERSE_REFRESH_LLM_TIMEOUT_MS=900000
UNIVERSE_REFRESH_VALIDATE_TIMEOUT_MS=20000

# Note: docker-compose.yml currently forwards only TUSHARE_TOKEN and PYSERVER_CACHE_DB
# to pyserver. To enable Tushare secondary in Docker, add these to pyserver.environment:
# MARKET_ENABLE_TUSHARE_SECONDARY=1
# STRICT_LIVE_DATA=1
